<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="20dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/task_details_back_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:text="@string/task_navigation_back"
            android:textAllCaps="false"
            android:textColor="@color/task_prompt_accent_light"
            app:backgroundTint="@android:color/transparent" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:text="@string/task_details_title"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/task_details_loading_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <ProgressBar
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/task_prompt_accent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/task_details_loading"
                android:textColor="@color/task_prompt_text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/task_details_error_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/task_details_error_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/task_prompt_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/task_details_retry_button"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="14dp"
                android:text="@string/retry"
                android:textAllCaps="false"
                app:backgroundTint="@color/mobilerun_primary" />

        </LinearLayout>

        <androidx.core.widget.NestedScrollView
            android:id="@+id/task_details_content_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingHorizontal="16dp"
            android:paddingBottom="24dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/task_details_status_chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="10dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="10dp"
                    android:paddingBottom="6dp"
                    android:textColor="@color/task_prompt_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/task_details_prompt_label"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/task_details_copy_prompt_button"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/task_details_copy_prompt_content_description"
                        android:focusable="true"
                        android:padding="2dp"
                        android:src="@drawable/baseline_content_copy_24"
                        app:tint="@color/task_prompt_text_secondary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/task_details_prompt_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textColor="@color/task_prompt_text_primary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/task_details_result_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/task_details_result_label"
                    android:textColor="@color/task_prompt_text_secondary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/task_details_result_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:maxLines="6"
                    android:scrollbars="vertical"
                    android:textColor="@color/task_prompt_text_primary"
                    android:textSize="15sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/task_details_metadata_label"
                        android:textColor="@color/task_prompt_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <ImageView
                        android:id="@+id/task_details_copy_metadata_button"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:contentDescription="@string/task_details_copy_metadata_content_description"
                        android:focusable="true"
                        android:padding="2dp"
                        android:src="@drawable/baseline_content_copy_24"
                        app:tint="@color/task_prompt_text_secondary" />

                </LinearLayout>

                <TextView
                    android:id="@+id/task_details_metadata_value"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/task_prompt_text_primary"
                    android:textSize="13sp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/task_details_trajectory_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:id="@+id/task_details_trajectory_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/task_prompt_rounded_ripple"
                            android:gravity="center_vertical"
                            android:minHeight="48dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/task_details_trajectory_label"
                                    android:textColor="@color/task_prompt_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/task_details_trajectory_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/task_details_trajectory_collapsed_hint"
                                    android:textColor="@color/task_prompt_text_secondary"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/task_details_trajectory_refresh_button"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:minWidth="0dp"
                                android:text="@string/task_details_trajectory_refresh"
                                android:textAllCaps="false"
                                android:textColor="@color/task_prompt_accent_light"
                                android:visibility="gone"
                                app:backgroundTint="@android:color/transparent" />

                            <ImageView
                                android:id="@+id/task_details_trajectory_chevron"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:layout_marginStart="4dp"
                                android:src="@drawable/chevron_right"
                                app:tint="@color/task_prompt_text_secondary" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/task_details_trajectory_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ProgressBar
                                android:id="@+id/task_details_trajectory_loading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:indeterminateTint="@color/task_prompt_accent"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/task_details_trajectory_message"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="13sp"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/task_details_trajectory_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:nestedScrollingEnabled="false"
                                android:visibility="gone"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/task_details_screenshot_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:visibility="gone"
                    app:cardBackgroundColor="@color/task_prompt_input_surface"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/task_prompt_stroke"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <LinearLayout
                            android:id="@+id/task_details_screenshot_header"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="@drawable/task_prompt_rounded_ripple"
                            android:gravity="center_vertical"
                            android:minHeight="48dp"
                            android:orientation="horizontal">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/task_details_screenshot_label"
                                    android:textColor="@color/task_prompt_text_primary"
                                    android:textSize="14sp"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/task_details_screenshot_subtitle"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="4dp"
                                    android:text="@string/task_details_screenshot_collapsed_hint"
                                    android:textColor="@color/task_prompt_text_secondary"
                                    android:textSize="12sp" />

                            </LinearLayout>

                            <ImageView
                                android:id="@+id/task_details_screenshot_chevron"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/chevron_right"
                                app:tint="@color/task_prompt_text_secondary" />

                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/task_details_screenshot_content"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:orientation="vertical"
                            android:visibility="gone">

                            <ProgressBar
                                android:id="@+id/task_details_screenshot_loading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:indeterminateTint="@color/task_prompt_accent"
                                android:visibility="gone" />

                            <TextView
                                android:id="@+id/task_details_screenshot_message"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:textColor="@color/task_prompt_text_secondary"
                                android:textSize="13sp"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/task_details_screenshot_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp"
                                android:nestedScrollingEnabled="false"
                                android:visibility="gone"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/task_details_load_all_screenshots_button"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="match_parent"
                                android:layout_height="48dp"
                                android:layout_marginTop="12dp"
                                android:text="@string/task_details_load_all_screenshots"
                                android:textAllCaps="false"
                                android:textColor="@color/task_prompt_text_primary"
                                android:visibility="gone"
                                app:backgroundTint="@android:color/transparent"
                                app:cornerRadius="12dp"
                                app:strokeColor="@color/task_prompt_stroke" />

                            <ProgressBar
                                android:id="@+id/task_details_screenshot_preview_loading"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:indeterminateTint="@color/task_prompt_accent"
                                android:visibility="gone" />

                            <ImageView
                                android:id="@+id/task_details_screenshot_image"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:adjustViewBounds="true"
                                android:background="@color/task_prompt_card_surface"
                                android:scaleType="fitCenter"
                                android:visibility="gone" />

                            <androidx.recyclerview.widget.RecyclerView
                                android:id="@+id/task_details_screenshot_gallery_list"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:nestedScrollingEnabled="false"
                                android:visibility="gone"
                                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                        </LinearLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </FrameLayout>

</LinearLayout>
